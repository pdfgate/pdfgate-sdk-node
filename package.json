{
  "name": "pdfgate",
  "version": "1.0.4",
  "description": "PDFGate API client",
  "author": "PDFGate <support@pdfgate.com> (https://pdfgate.com/)",
  "homepage": "https://pdfgate.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/pdfgate/pdfgate-sdk-node.git"
  },
  "bugs": "https://github.com/pdfgate/pdfgate-sdk-node/issues",
  "keywords": [
    "pdfgate",
    "pdf",
    "pdf-api",
    "html-to-pdf",
    "html-to-pdf-api",
    "pdf-generation",
    "pdf-conversion",
    "fillable-pdf",
    "pdf-forms",
    "pdf-form-fields",
    "flatten-pdf",
    "compress-pdf",
    "watermark-pdf",
    "protect-pdf",
    "encrypt-pdf",
    "node",
    "nodejs",
    "typescript"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "files": [
    "dist",
    "cjs.cjs",
    "README.md",
    "LICENSE"
  ],
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./cjs.cjs"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:types": "tsc -p tsconfig.esm.json --emitDeclarationOnly",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "docs": "typedoc --out docs src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3"
  }
}
